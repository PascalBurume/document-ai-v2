# Server-side only. Never exposed to the browser.
# Copy this file to .env and put your real key there — .env is gitignored, this file is NOT.
MISTRAL_API_KEY=your_key_here

# OpenAI powers visual re-reading, faithful SVG reconstruction, reconstruction critique,
# text recovery, and student explanations. Kept server-side; never exposed to the browser.
OPENAI_API_KEY=your_openai_key_here
# Optional override for the multimodal reasoning model.
OPENAI_VISION_MODEL=gpt-5.6

# Optional
PORT=8787
