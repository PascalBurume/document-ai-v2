# Server-side only. Never exposed to the browser.
# Copy this file to .env and put your real key there — .env is gitignored, this file is NOT.
MISTRAL_API_KEY=your_key_here

# Optional — enables the Convert tab's "Redraw as diagram" (xAI Grok). Without it, redraws
# fall back to a stub. Get a key at https://console.x.ai
XAI_API_KEY=xai-your_key_here
# Optional — override the Grok vision model used for figure redraws.
GROK_VISION_MODEL=grok-2-vision

# Optional
PORT=8787
