{
  "name": "document-ai",
  "private": true,
  "version": "1.0.0",
  "description": "OpenAI-powered document intelligence and deterministic 2D-to-3D learning workspace",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace server && npm run build --workspace web",
    "build:epure-ir": "tsx scripts/build-epure-ir.mts",
    "start": "npm run start --workspace server",
    "test": "tsx --test server/src/*.test.ts web/src/lib/*.test.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.23.1"
  }
}
